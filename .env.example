# Gemini AI API Key
# Get it from: https://makersuite.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Telegram Bot Configuration
# Create bot with @BotFather on Telegram
VITE_TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
VITE_TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Market Data API (Optional)
# Get free key from: https://twelvedata.com
VITE_TWELVE_DATA_API_KEY=your_twelve_data_key_here

# Alpaca Trading API (Optional - for real trading)
# Get from: https://alpaca.markets
VITE_ALPACA_API_KEY=your_alpaca_api_key_here
VITE_ALPACA_API_SECRET=your_alpaca_api_secret_here
VITE_ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Supabase Configuration (Optional - for cloud database)
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# For Vercel Serverless Functions (Backend API)
# Add these in Vercel Dashboard → Settings → Environment Variables
GEMINI_API_KEY=your_gemini_api_key_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here